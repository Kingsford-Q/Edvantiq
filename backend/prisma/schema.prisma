datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model School {
  id       String @id @default(uuid())
  name     String
  type     String
  location String

  roles Role[]

  users         User[]
  students      Student[]
  teachers      Teacher[]
  classes       Class[]
  subjects      Subject[]
  academicYears AcademicYear[]

  enrollments        Enrollment[]
  teacherAssignments TeacherAssignment[]
  attendanceSessions AttendanceSession[]
  assessments        Assessment[]
  feeStructures      FeeStructure[]
  feePayments        FeePayment[]
  announcements      Announcement[]
  messages           Message[]
  notifications      Notification[]
  accessRequests     AccessRequest[]
  auditLogs          AuditLog[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  Invoice       Invoice[]
  ParentStudent ParentStudent[]
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  fullName String

  // 🔥 USED BY ADMIN + STAFF + PARENTS
  phoneNumber String?
  address     String?
  profileImageUrl String?
  emergencyContact String?

  // optional admin metadata
  position String? // e.g. Principal, Headmaster
  staffCode String?

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  // 🔥 NULLABLE: SUPER_ADMIN is a platform-level account with no home school
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  notifications    Notification[]
  accessRequests   AccessRequest[]
  auditLogs        AuditLog[]

  student Student?
  teacher Teacher?
  staffProfile StaffProfile?

  parentLinks ParentStudent[] @relation("ParentRelation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id       String  @id @default(uuid())
  name     String
  isSystem Boolean @default(false)

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  users       User[]
  permissions Permission[]

  createdAt DateTime @default(now())
}

model Permission {
  id     String @id @default(uuid())
  action String

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
}

model Student {
  id String @id @default(uuid())

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  fullName String
  indexNo  String?

  // 🔥 ENRICHMENT FIELDS
  dateOfBirth DateTime?
  gender      String?
  address     String?
  phoneNumber String?

  // optional image (not required)
  profileImageUrl String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  enrollments       Enrollment[]
  attendanceRecords AttendanceRecord[]
  results           AssessmentResult[]
  payments          FeePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  StudentFee StudentFee[]
  Invoice    Invoice[]

  parentLinks ParentStudent[]
}

model StudentFee {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  feeId String
  fee   FeeStructure @relation(fields: [feeId], references: [id])

  amountDue Int

  schoolId String
}

model Teacher {
  id String @id @default(uuid())

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  fullName String
  subject  String?

  // 🔥 ENRICHMENT FIELDS
  email       String?
  phoneNumber String?
  address     String?
  qualification String?
  employmentType String? // e.g FULL_TIME, PART_TIME, CONTRACT
  hireDate    DateTime?

  profileImageUrl String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  assignments        TeacherAssignment[]
  attendanceSessions AttendanceSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Class {
  id String @id @default(uuid())

  name  String
  level String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  enrollments        Enrollment[]
  teacherAssignments TeacherAssignment[]
  attendanceSessions AttendanceSession[]
  assessments        Assessment[]
  feeStructures      FeeStructure[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subject {
  id String @id @default(uuid())

  name String

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  teacherAssignments TeacherAssignment[]
  attendanceSessions AttendanceSession[]
  assessments        Assessment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
}

model TeacherAssignment {
  id String @id @default(uuid())

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
}

model AttendanceSession {
  id String @id @default(uuid())

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id])

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])

  date DateTime

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  records AttendanceRecord[]

  createdAt DateTime @default(now())
}

model AttendanceRecord {
  id String @id @default(uuid())

  sessionId String
  session   AttendanceSession @relation(fields: [sessionId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  status AttendanceStatus

  createdAt DateTime @default(now())

  @@unique([sessionId, studentId])
}

model Assessment {
  id        String         @id @default(uuid())
  title     String
  type      AssessmentType
  totalMark Int

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])

  results AssessmentResult[]

  createdAt DateTime @default(now())
}

model StaffProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  position   String
  department String?
  schoolId   String

  createdAt DateTime @default(now())
}

model AssessmentResult {
  id String @id @default(uuid())

  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  score  Int
  remark String?

  createdAt DateTime @default(now())
}

model FeeStructure {
  id String @id @default(uuid())

  title  String
  amount Int
  term   String?

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])

  payments FeePayment[]

  studentFees StudentFee[]

  createdAt   DateTime      @default(now())
  InvoiceItem InvoiceItem[]
}

model FeePayment {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  feeId String
  fee   FeeStructure @relation(fields: [feeId], references: [id])

  amountPaid Int
  method     String

  date DateTime @default(now())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])
}

model Announcement {
  id String @id @default(uuid())

  title   String
  message String
  type    String

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
}

model Message {
  id String @id @default(uuid())

  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])

  receiverId String?
  receiver   User?   @relation("ReceivedMessages", fields: [receiverId], references: [id])

  content String

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
}

model AcademicYear {
  id   String @id @default(uuid())
  name String

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  attendanceSessions AttendanceSession[]
  assessments        Assessment[]
  feeStructures      FeeStructure[]

  createdAt DateTime @default(now())
}

model Notification {
  id      String @id @default(uuid())
  title   String
  message String
  type    String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
}

model AccessRequest {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  requestedById String
  requestedBy   User   @relation(fields: [requestedById], references: [id])

  status AccessRequestStatus @default(PENDING)

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  action   String
  entity   String?
  entityId String?

  metadata Json?

  createdAt DateTime @default(now())
}

model Invoice {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  totalAmount Int
  status      InvoiceStatus @default(UNPAID)

  createdAt   DateTime      @default(now())
  InvoiceItem InvoiceItem[]
}

model InvoiceItem {
  id String @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  feeId          String
  amount         Int
  FeeStructure   FeeStructure? @relation(fields: [feeStructureId], references: [id])
  feeStructureId String?
}

model ParentStudent {
  id String @id @default(uuid())

  parentId String
  parent   User   @relation("ParentRelation", fields: [parentId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum AssessmentType {
  CA
  EXAM
  QUIZ
}
